<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="SQL_MULTI_VALUE_HELPER.MainWindow"
        Title="SQL Multi Value Helper"
        Height="300" Width="800"
             Icon="pack://application:,,,/Resources/appstore.png"

        Background="#1E1E1E">
    

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Başlık -->
        <TextBlock Text="SQL Multi Value Helper"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="White"
                   Margin="0,0,0,10"/>

        <!-- Açıklama -->
        <TextBlock Grid.Row="1"
                   Text="Komutu yukarı yazın, değerleri aşağıya girin. Dönüştür butonuna bastığınızda otomatik olarak virgülle ayrılır, parantez içine alınır ve panoya kopyalanır."
                   TextWrapping="Wrap"
                   Foreground="#CCCCCC"
                   Margin="0,0,0,15"/>

        <!-- Input Alanları -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Komut -->
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Komut"
                           Foreground="White"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="txtCommand"
                         Height="35"
                         Background="#2D2D2D"
                         Foreground="White"
                         BorderBrush="#444"
                         Padding="8" />
            </StackPanel>

            <!-- Değerler -->
            <StackPanel Grid.Column="1">
                <TextBlock Text="Değerler"
                           Foreground="White"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="txtValues"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Background="#2D2D2D"
                         Foreground="White"
                         BorderBrush="#444"
                         Padding="8"/>
            </StackPanel>
        </Grid>

        <!-- Buton -->
        <Button Grid.Row="3"
                Content="Dönüştür ve Kopyala"
                Height="40"
                Background="#007ACC"
                Foreground="White"
                BorderBrush="Transparent"
                FontWeight="Bold"
                Cursor="Hand"
                Click="Button_Click"/>
    </Grid>
</Window>